<!DOCTYPE html>
<html>
<head>
    <title>My Client Page</title>

    <link rel="icon" href="favicon.ico">

    <link rel="stylesheet" href="style.css">
</head>
<body>

    <h1>Welcome to <span class="highlight">My Client Page</span></h1>

    <p>This page shows a styled image example.</p>

    <img src="image.jpg" alt="Profile Image" class="styled-image">

</body>
</html>


body {
    font-family: Arial;
    text-align: center;
    background-color: #f4f4f4;
}

.highlight {
    color: #e74c3c;
}

.styled-image {
    width: 220px;
    height: auto;

    border: 4px solid #2c3e50;

    border-radius: 15px;

    box-shadow: 2px 2px 10px gray;

    margin-top: 20px;
}